#!/usr/bin/env bash

set -euo pipefail

show_text() {

    yad --text-info \
        --width=1000 \
        --height=700 \
        --button="Chiudi:0" \
        --fontname="UbuntuMono Nerd Font Mono 12.5" \
        --title="$1"
}

choice=$(
    printf "%s\n" \
        "Run all" \
        "Run group" \
        "Status" \
        "Logs" |
        rofi -dmenu \
            -i \
            -p "BK Manager"
)

case "$choice" in

"Run all")

    sudo bk-manager run --all |
        yad --text-info \
            --title="BK Manager"

    ;;

"Run group")

    group=$(
        bk-manager list |
            rofi -dmenu \
                -i \
                -p "Group"
    )

    [ -z "${group:-}" ] && exit 0

    sudo bk-manager run "$group" |
        yad --text-info \
            --title="BK Manager"

    ;;

"Status")

    bk-manager status |
        show_text "BK Manager Status"

    ;;

"Logs")

    bk-manager logs |
        show_text "BK Manager Logs"
    ;;

esac
